# RetailMind Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask settings
SECRET_KEY=your-super-secret-key-change-this
DEBUG=True
FLASK_ENV=development

# Google OAuth (required for authentication)
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT settings
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_EXPIRATION_HOURS=24

# Direct Supabase connection for backend/admin actions
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Legacy local database path
DATABASE_PATH=database/retailmind.db

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://localhost:3000
